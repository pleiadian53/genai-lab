# Template — copy to .env and fill in. .env is gitignored.
# cp .env.example .env

# ---------------------------------------------------------------------------
# Experiment tracking (Weights & Biases)
# Sign up at https://wandb.ai, then get an API key at
# https://wandb.ai/authorize
# ---------------------------------------------------------------------------
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=genai-lab

# ---------------------------------------------------------------------------
# HuggingFace (datasets, model weights)
# https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# RunPod (used by SkyPilot for ops/provision_cluster.py)
# ---------------------------------------------------------------------------
RUNPOD_API_KEY=
